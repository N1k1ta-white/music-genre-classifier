#!/bin/sh

# === UNIVERSAL CONFIGURATION ===
# Use 'python' instead of a specific path. 
# This works on Windows AND Linux if Python is in the system PATH.
PYTHON_CMD="python"
# ===============================

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep ".ipynb$")

if [ -z "$FILES" ]; then
    exit 0
fi

for FILE in $FILES; do
    echo "Auto-converting: $FILE..."
    
    # We use "python -m jupytext" which works cross-platform
    if "$PYTHON_CMD" -m jupytext --to py:percent "$FILE"; then
        git add "${FILE%.ipynb}.py"
    else
        echo "Error: Failed to convert $FILE"
        exit 1
    fi
done

exit 0